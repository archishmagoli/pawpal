classDiagram
    class Owner {
        +str name
        +int available_time
        +list~Pet~ pets
        +add_pet(pet)
        +remove_pet(name)
        +get_pet(name)
    }

    class Pet {
        +str name
        +int age
        +str species
        +list~Task~ tasks
        +add_task(task)
        +remove_task(name)
        +get_tasks()
    }

    class Task {
        +str name
        +int duration
        +str priority
        +str category
        +str|None start_time
    }

    class Schedule {
        +date date
        +Pet pet
        +int available_time
        +list~Task~ tasks
        +generate_plan()
        +display_plan()
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "many" Task : has
    Schedule "1" --> "1" Pet : plans for
    Schedule "1" --> "many" Task : contains
